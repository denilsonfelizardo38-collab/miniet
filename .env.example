# Database (PostgreSQL) — Sugestão: Supabase (grátis)
# 1. Cria conta em https://supabase.com
# 2. Cria projecto "minigest"
# 3. Vai a Project Settings > Database > Connection string
# 4. Cola aqui (algo como: postgresql://postgres:abc@db.xxx.supabase.co:5432/postgres)
DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="gerar-uma-string-aleatoria-aqui"
NEXTAUTH_URL="https://minigest.vercel.app"
